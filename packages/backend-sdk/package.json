{
  "name": "@authstack/backend-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Authstack backend API",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/authstack-org/typescript-packages.git",
    "directory": "packages/backend-sdk"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "openapi/authstack.openapi.json",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "openapi:fetch": "node ./scripts/fetch-openapi.mjs",
    "generate:client": "openapi-ts -i ./openapi/authstack.openapi.json -o ./src/generated -c @hey-api/client-fetch",
    "generate": "pnpm run openapi:fetch && pnpm run generate:client",
    "check:generated": "node ./scripts/check-generated.mjs",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run generate && pnpm run check:generated && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.9.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.67.2",
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
